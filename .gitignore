# LocalFind - Production .gitignore

# ============================================
# Environment & Configuration
# ============================================
.env
.env.local
.env.production
.env.*.local
.env*
config.local.js
secrets.json
credentials.json
*credentials*.json
*adminsdk*.json

# ============================================
# IDE & Editor Files
# ============================================
.vscode/
.vscode/settings.json
.idea/
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace
.DS_Store

# ============================================
# Logs
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
error.log
access.log

# ============================================
# Dependencies
# ============================================
node_modules/
vendor/
bower_components/
.next/
target/
__pycache__/
package-lock.json
yarn.lock
composer.lock

# ============================================
# Build & Distribution
# ============================================
dist/
build/
*.min.js
*.min.css
*.map

# ============================================
# Temporary Files
# ============================================
tmp/
temp/
*.tmp
*.pid
*.bak
*.orig
*_old.*
*_copy.*
*.cache
.cache/
.sass-cache/

# ============================================
# Database
# ============================================
*.sql
*.sqlite
*.db

# ============================================
# Backups
# ============================================
backups/
*.backup

# ============================================
# Uploads (if implemented)
# ============================================
uploads/
user-uploads/

# ============================================
# SSL Certificates
# ============================================
*.pem
*.key
*.crt
*.csr

# ============================================
# Testing
# ============================================
coverage/
.nyc_output/
test-results/

# ============================================
# OS Files
# ============================================
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ============================================
# Archives
# ============================================
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip

# ============================================
# Documentation Builds
# ============================================
docs/_build/

# ============================================
# Internal Documentation (not for public repo)
# ============================================
*_AUDIT_REPORT.md
*_CHECKLIST.md
*_REPORT.md
INTERNAL_NOTES.md

# ============================================
# Keep These Files
# ============================================
!.htaccess
!.gitignore
!README.md
!LICENSE
